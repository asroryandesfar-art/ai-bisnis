APP_URL=https://your-public-domain.example

# --- Database (PostgreSQL, asyncpg) ---
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/botnesia
# Connection pool per-proses (opsional; default 2..20). Untuk horizontal
# scaling: kecilkan per-proses lalu tambah replika, atau pakai PgBouncer.
# DB_POOL_MIN_SIZE=2
# DB_POOL_MAX_SIZE=20
# Set 1 bila DATABASE_URL mengarah ke PgBouncer (transaction pooling):
# mematikan prepared-statement cache asyncpg (statement_cache_size=0).
# DB_PGBOUNCER=0

# --- AI providers (fill at least one; keys are placeholders, never commit real ones) ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# WAJIB kuat & acak (min 32 char). Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# JANGAN pakai nilai default/lemah. Server memberi peringatan keras bila lemah,
# dan MENOLAK boot jika STRICT_SECRETS=1.
SECRET_KEY=
# Key TERPISAH untuk enkripsi kredensial integrasi tersimpan (Gmail/WhatsApp/Meta).
# Kosongkan untuk memakai SECRET_KEY (default, backward-compat). SAAT MEROTASI
# SECRET_KEY, isi ini dengan nilai SECRET_KEY LAMA agar integrasi lama tetap terbaca.
INTEGRATION_ENCRYPTION_KEY=
# Set 1 di produksi untuk memaksa server menolak boot bila SECRET_KEY lemah (fail-closed).
STRICT_SECRETS=0
# Set 1 agar GET /media/{path} WAJIB tautan bertanda tangan (?sig=) yang sah
# (cegah akses file media lintas-tenant via URL tebakan). Default 0 (URL lama
# tetap terbuka). Endpoint yang mengembalikan URL media selalu menandatanganinya,
# jadi mengaktifkan ini tidak memutus URL baru.
MEDIA_REQUIRE_SIGNATURE=0
# Origin dashboard yang diizinkan cross-origin (comma-separated). Kosong =
# default aman (APP_URL + localhost dev). "*" = izinkan semua (escape hatch).
# Endpoint publik widget (/chat, /bots/{id}/config, /health) SELALU dibuka.
CORS_ALLOWED_ORIGINS=
# Set 1 hanya di dev untuk mengekspos Swagger /docs, /redoc, /openapi.json.
# Default 0 (produksi tidak membocorkan skema API).
ENABLE_API_DOCS=0
# Lindungi endpoint /metrics (Prometheus). Jika kosong, /metrics TERBUKA tanpa
# auth — WAJIB diisi sebelum expose ke jaringan publik. Prometheus lalu kirim
# header `Authorization: Bearer <token>`.
METRICS_AUTH_TOKEN=

# DeepSeek "3 otak" — SATU API key (DEEPSEEK_API_KEY) untuk tiga model.
# Semua nama model bisa diganti di sini tanpa mengubah kode. THINKING sengaja
# default deepseek-reasoner (R1) — dipertahankan. Lihat docs/DEEPSEEK_BOTNESIA_BRAIN.md
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_THINKING=deepseek-reasoner
DEEPSEEK_MODEL_PRO=deepseek-v4-pro

# Platform-managed business channels
# Customers connect channels from the dashboard without entering these secrets.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Meta app credentials used by WhatsApp Embedded Signup
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_VERIFY_TOKEN=
META_OAUTH_REDIRECT_URI=https://your-public-domain.example/api/integrations/meta/oauth/callback

# Encrypt channel credentials stored by the application
CHANNEL_ENCRYPTION_KEY=

# Phase 3 Multimodal — image generation provider abstraction.
# Default provider is "replicate" (uses REPLICATE_API_TOKEN, already configured for media).
# Each alternative provider only activates once its key below is filled in; otherwise it
# reports as unavailable instead of failing the whole feature.
IMAGE_PROVIDER=replicate
# When a caller does NOT request a specific provider (e.g. Chat+Image, or
# /api/images/generate with provider left blank), try this order and use the
# first available+successful one. Explicit provider requests are unaffected.
IMAGE_PROVIDER_FALLBACK_ORDER=google_imagen,replicate
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
STABILITY_API_KEY=
FAL_API_KEY=
IMAGE_MODERATION_ENABLED=true
