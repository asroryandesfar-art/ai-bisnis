{
  "title": "BotNesia — Platform Observability",
  "uid": "botnesia-platform",
  "timezone": "Asia/Jakarta",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s) by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (route) (rate(bn_http_requests_total[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (5xx %) ",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(bn_http_errors_total[5m])) / sum(rate(bn_http_requests_total[5m]))",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 } }
    },
    {
      "id": 3,
      "title": "Latency p50 / p95 / p99 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(bn_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(bn_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(bn_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 4,
      "title": "In-Progress Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum by (route) (bn_http_requests_in_progress)", "legendFormat": "{{route}}" }
      ]
    },
    {
      "id": 5,
      "title": "AI Agent Request Rate by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum by (agent, status) (rate(bn_ai_requests_total[5m]))", "legendFormat": "{{agent}} — {{status}}" }
      ]
    },
    {
      "id": 6,
      "title": "AI Agent Latency p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, agent) (rate(bn_ai_request_duration_seconds_bucket[5m])))", "legendFormat": "{{agent}}" }
      ]
    },
    {
      "id": 7,
      "title": "Token Usage Rate by Tenant (tokens/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        { "expr": "sum by (org_id, kind) (rate(bn_ai_tokens_total[5m])) * 60", "legendFormat": "{{org_id}} — {{kind}}" }
      ]
    },
    {
      "id": 8,
      "title": "Process CPU (s/s) & Memory (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "rate(bn_process_cpu_seconds_total[5m])", "legendFormat": "CPU (cores)" },
        { "expr": "bn_process_resident_memory_bytes", "legendFormat": "RSS (bytes)" }
      ]
    },
    {
      "id": 9,
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        { "expr": "bn_db_pool_size", "legendFormat": "pool size" },
        { "expr": "bn_db_pool_in_use", "legendFormat": "in use" }
      ]
    }
  ]
}
